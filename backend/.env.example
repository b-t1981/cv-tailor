OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

GROQ_API_KEY=gsk-your-groq-key
GROQ_MODEL=llama-3.3-70b-versatile

# Repli automatique si quota Groq atteint — https://cloud.cerebras.ai
CEREBRAS_API_KEY=csk-your-cerebras-key
CEREBRAS_MODEL=llama-3.3-70b

# Traduction CV (recommandé) — https://www.deepl.com/pro-api
# DEEPL_API_KEY=your-deepl-key:fx
# DEEPL_USE_FREE_API=true

ANTHROPIC_API_KEY=sk-ant-your-claude-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

DEFAULT_LLM_PROVIDER=groq
PROMPTS_FILE=prompts/default_prompts.json
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
# Local : http://localhost:3000
# Vercel : https://votre-app.vercel.app (plusieurs origines séparées par des virgules)
CORS_ORIGINS=http://localhost:3000

# PDF : en local, installez LibreOffice (soffice dans le PATH) pour un PDF fidèle au DOCX.
# PDF_USE_WORD=true  # Windows uniquement — utilise Microsoft Word (peut ouvrir une fenêtre imprimante)
# MAX_UPLOAD_BYTES=10485760
# OUTPUT_TTL_HOURS=48
# RATE_LIMIT_PER_MINUTE=60
# SESSION_TTL_HOURS=168
# ALLOW_PROMPT_WRITES=true
# ADMIN_API_TOKEN=change-me-long-random-token
# COOKIE_SECURE=true
# COOKIE_SAMESITE=none
