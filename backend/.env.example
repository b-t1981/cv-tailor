OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

GROQ_API_KEY=gsk-your-groq-key
GROQ_MODEL=llama-3.3-70b-versatile

ANTHROPIC_API_KEY=sk-ant-your-claude-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

DEFAULT_LLM_PROVIDER=groq
PROMPTS_FILE=prompts/default_prompts.json
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
# Local : http://localhost:3000
# Vercel : https://votre-app.vercel.app (plusieurs origines séparées par des virgules)
CORS_ORIGINS=http://localhost:3000

# PDF_USE_WORD=true  # utilise Microsoft Word pour le PDF (peut ouvrir une fenêtre imprimante)
# MAX_UPLOAD_BYTES=10485760
# OUTPUT_TTL_HOURS=48
# RATE_LIMIT_PER_MINUTE=60
# SESSION_TTL_HOURS=168
# ALLOW_PROMPT_WRITES=true
# ADMIN_API_TOKEN=change-me-long-random-token
# COOKIE_SECURE=true
# COOKIE_SAMESITE=none
