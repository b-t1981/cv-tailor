# Variables à configurer dans le dashboard Vercel (Settings → Environment Variables).
# Root Directory du projet Vercel : frontend

# URL publique du backend (Render, Railway, etc.) — obligatoire en production.
# Recommandé : appels directs depuis le navigateur (évite les limites de taille/timeout du proxy Vercel).
NEXT_PUBLIC_API_URL=https://cv-tailor-api.onrender.com

# Cible du proxy Next.js /api-backend → backend (rewrites dans next.config.js).
# Utile si NEXT_PUBLIC_API_URL n'est pas défini ; à définir dans tous les cas pour cohérence SSR.
BACKEND_URL=https://cv-tailor-api.onrender.com

# Backend Render — sécurité (recommandé en production) :
# ALLOW_PROMPT_WRITES=false
# ADMIN_API_TOKEN=<token-long-aleatoire>
# COOKIE_SECURE=true
# COOKIE_SAMESITE=none
# CORS_ORIGINS=https://votre-app.vercel.app

# Ne pas définir sur Vercel (géré automatiquement par la plateforme) :
# VERCEL_GIT_COMMIT_MESSAGE — utilisé par scripts/write-build-info.mjs pour la version affichée
