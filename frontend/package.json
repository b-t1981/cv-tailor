{
  "name": "cv-tailor-frontend",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "write-build-info": "node scripts/write-build-info.mjs",
    "install-git-hooks": "node scripts/install-git-hooks.mjs",
    "predev": "node scripts/write-build-info.mjs",
    "prebuild": "node scripts/write-build-info.mjs",
    "postinstall": "node scripts/install-git-hooks.mjs",
    "dev": "next dev --turbo",
    "dev:clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && next dev --turbo",
    "build": "next build",
    "start": "next start -p 3000",
    "start:prod": "npm run build && npm run start",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
